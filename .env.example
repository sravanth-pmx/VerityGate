# Project Verity-H — Environment Variables
# Copy this file to .env and fill in your values.
# Only ONE mode section should be active at a time.

# ── LLM mode ──────────────────────────────────────────────────────────
# "mock"   — canned responses for offline tests (no API key needed)
# "groq"   — Groq API (fast, free tier, OpenAI-compatible)
# "api"    — Any OpenAI-compatible endpoint (also used for Ollama local)
# "hf_api" — HuggingFace Inference API
LLM_MODE=mock

# ── Groq API (LLM_MODE=groq) ──────────────────────────────────────────
# Get your key: https://console.groq.com/keys
# Models:       https://console.groq.com/docs/models
#
# Recommended models for this pipeline:
#   llama-3.3-70b-versatile   — best results, free tier
#   llama-3.1-8b-instant      — fastest, good for quick iteration
#   qwen-qwen3-32b            — closest to the HF-validated model
#   gemma2-9b-it              — solid smaller option
#
GROQ_API_KEY=gsk_your-key-here
# MODEL_NAME=llama-3.3-70b-versatile

# ── OpenAI-compatible API (LLM_MODE=api) ──────────────────────────────
# Works for: real OpenAI, Azure OpenAI, or any compatible endpoint.
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_NAME=gpt-4o-mini

# ── Ollama local (LLM_MODE=api) ───────────────────────────────────────
# Ollama uses the same "api" mode but with a local base URL.
# Pull a model first: ollama pull llama3.2
# Check exact name:   ollama list
#
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL_NAME=llama3.2

# ── HuggingFace Inference API (LLM_MODE=hf_api) ──────────────────────
HF_API_KEY=hf_your-key-here
# MODEL_NAME=Qwen/Qwen3-4B-Instruct-2507

# ── Shared model settings (apply to all API modes) ────────────────────
MODEL_NAME=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ── Rate limiting ─────────────────────────────────────────────────────
# Delay in seconds between LLM calls.
#   Groq free tier:  0.5 (stays under ~30 RPM)
#   HF Serverless:   2.0 (safe default)
#   Ollama local:    0   (no limit needed)
LLM_CALL_DELAY=2

# Per-minute call ceiling. Set to 0 to disable.
#   Groq free tier:  30
#   Ollama local:    0
LLM_MAX_CALLS_PER_MINUTE=30
